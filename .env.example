OPENAI_API_KEY=sk-your-key-here
CHAT_BASE_URL=ddd
CHAT_API_KEY=dddd
CHAT_MODEL=openclaw

# Display name and persona used by the avatar (client UI + server system prompts).
# VITE_ prefix is required so Vite exposes it to the browser bundle; the server
# also reads the same variable via dotenv.
VITE_AVATAR_NAME=kenken64

# TTS voice used by the avatar. Uncomment one line:
# Male voices:
TTS_VOICE=onyx
# TTS_VOICE=echo
# TTS_VOICE=fable
# TTS_VOICE=alloy
# Female voices:
# TTS_VOICE=nova
# TTS_VOICE=shimmer